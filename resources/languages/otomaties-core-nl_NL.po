#: app/Modules/Security.php:38
msgid ""
"Disable debugging for better security. Add <code>define( 'WP_DEBUG', false );"
"</code> to wp-config.php"
msgstr ""
"Schakel debugging uit voor betere beveiliging. Voeg "
"<code>define( 'WP_DEBUG', false );</code> toe aan wp-config.php"

#: app/Modules/Security.php:44
#, php-format
msgid "Your debug.log file is publicly accessible. Remove <code>%s</code>"
msgstr ""
"Uw debug.log bestand is publiekelijk toegankelijk. Verwijder <code>%s</code>"

#: app/Modules/Security.php:50
msgid ""
"Disallow file editing for better security. Add "
"<code>define( 'DISALLOW_FILE_EDIT', true );</code> to wp-config.php"
msgstr ""
"Verbied het bewerken van bestanden voor betere beveiliging. Voeg "
"<code>define( 'DISALLOW_FILE_EDIT', true );</code> toe aan wp-config.php"

#: app/Modules/Security.php:60
msgid ""
"Install & activate Wordfence, Sucuri Security or WP Defender for optimal "
"security."
msgstr ""
"Installeer en activeer Wordfence, Sucuri Security of WP Defender voor een "
"optimale beveiliging."

#: app/Modules/Security.php:69
msgid "You have some security concerns"
msgstr "Je hebt enkele veiligheidszorgen"

#: app/Modules/Security.php:98
msgid "Could not reset your password."
msgstr "We konden je wachtwoord niet resetten."

#: app/Modules/Security.php:103
#, php-format
msgid ""
"Could not log you in. If this problem persists, <a href=\"%s\">try resetting "
"your password</a>"
msgstr ""
"Kon u niet inloggen. Als dit probleem zich blijft voordoen, <a "
"href=\"%s\">probeer dan uw wachtwoord opnieuw in te stellen</a>"

